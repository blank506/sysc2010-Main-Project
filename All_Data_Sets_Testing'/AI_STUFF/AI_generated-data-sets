import numpy as np
import pandas as pd

# ECG
fs = 250
t = np.arange(0,60,1/fs)

ecg = 0.8*np.sin(2*np.pi*1.2*t)
ecg += 0.2*np.random.randn(len(t))

pd.DataFrame({
"time":t,
"signal":ecg
}).to_csv("ecg_signal.csv",index=False)


# RESPIRATION
fs = 25
t = np.arange(0,120,1/fs)

resp = np.sin(2*np.pi*0.25*t)
resp += 0.05*np.random.randn(len(t))

pd.DataFrame({
"time":t,
"signal":resp
}).to_csv("respiration_signal.csv",index=False)


# TEMPERATURE
t = np.arange(0,2000)

temp = 22 + 0.005*t + 0.1*np.random.randn(len(t))

pd.DataFrame({
"time":t,
"signal":temp
}).to_csv("temperature_signal.csv",index=False)