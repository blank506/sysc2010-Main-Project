# Updated Sensor Signal Processing Tool
import numpy as np
import pandas as pd
import tkinter as tk
from tkinter import filedialog, ttk, messagebox
from scipy.signal import butter, filtfilt, firwin, find_peaks
from scipy.fft import fft, fftfreq
import matplotlib.pyplot as plt

# ---------------------------
# GLOBAL VARIABLES (for GUI)
# ---------------------------
time = None
signal = None
original_signal = None
processed_signal = None
fs = None

# ---------------------------
# PREPROCESSING
# ---------------------------
def preprocess_signal(sig):
    """Fill missing values and normalize to zero mean, unit variance."""
    sig_series = pd.Series(sig)
    sig_filled = sig_series.interpolate().bfill().values  # linear interpolate, back-fill if needed
    if np.std(sig_filled) == 0:
        return sig_filled  # avoid division by zero
    sig_norm = (sig_filled - np.mean(sig_filled)) / np.std(sig_filled)
    return sig_norm

# ---------------------------
# CSV LOADER
# ---------------------------
def load_csv():
    global time, signal, original_signal, processed_signal, fs

    file_path = filedialog.askopenfilename(filetypes=[("CSV Files","*.csv")])
    if not file_path:
        return

    try:
        df = pd.read_csv(file_path)
    except Exception as e:
        messagebox.showerror("CSV Load Error", f"Could not read CSV: {e}")
        return

    # Detect time column (support t, time, time24, Datetime, Datetime1)
    tcol = None
    if "time" in df.columns:
        tcol = "time"
    elif "t" in df.columns:
        tcol = "t"
    elif "time24" in df.columns:
        tcol = "time24"
    elif "Datetime" in df.columns:
        tcol = "Datetime"
    elif "Datetime1" in df.columns:
        tcol = "Datetime1"

    if tcol is not None:
        # Parse datetime if possible (handles full datetime or HH:MM:SS)
        try:
            dt = pd.to_datetime(df[tcol])
        except Exception as e:
            messagebox.showerror("Time Parse Error", f"Unable to parse time column '{tcol}': {e}")
            return
        # Compute elapsed seconds from start
        elapsed = (dt - dt.iloc[0]).dt.total_seconds().values
        time = elapsed.copy()
        # If using "Datetime", apply 5-day filtering as per original spec
        if tcol == "Datetime":
            start = dt.iloc[0]
            end = start + pd.Timedelta(days=5)
            mask = dt <= end
            df = df[mask].reset_index(drop=True)
            time = time[mask]
    else:
        # No time column found; fallback to index
        time = np.arange(len(df))

    # If after filtering time length is 0, error
    if time is None or len(time) == 0:
        messagebox.showerror("Time Error", "No valid time data found.")
        return

    # Determine signal column
    if "ecg" in df.columns:
        sigcol = "ecg"
    if "signal" in df.columns:
        sigcol = "signal"
    elif "lead_I" in df.columns:
        sigcol = "lead_I"
    elif "DAYTON_MW" in df.columns:
        sigcol = "DAYTON_MW"
    else:
        # pick the first numeric column as fallback
        num_cols = df.select_dtypes(include=[np.number]).columns
        if len(num_cols) == 0:
            messagebox.showerror("Signal Error", "No numeric signal column found.")
            return
        sigcol = num_cols[0]

    signal = df[sigcol].values
    original_signal = signal.copy()
    processed_signal = preprocess_signal(signal)

    # Compute sampling frequency robustly
    dt = np.diff(time)
    dt = dt[dt > 0]  # ignore zero or negative intervals
    if len(dt) == 0:
        messagebox.showerror("Frequency Error", "Insufficient time data to compute sampling rate.")
        fs = None
    else:
        fs = 1.0 / np.mean(dt)

    # Plot
    plot_time()

# ---------------------------
# FILTERS
# ---------------------------
def butter_filter(data, cutoff, fs, btype, order=4):
    nyq = 0.5 * fs
    if isinstance(cutoff, (list, tuple)):
        Wn = [c/nyq for c in cutoff]
    else:
        Wn = cutoff/nyq
    b, a = butter(order, Wn, btype=btype)
    # Ensure padlen < data length to avoid warnings
    try:
        return filtfilt(b, a, data)
    except ValueError:
        # If padlen > len(data), reduce padlen by using 'gust' method
        return filtfilt(b, a, data, method='gust')

def fir_filter(data, cutoff, fs, btype, numtaps=101):
    nyq = 0.5 * fs
    if btype == 'low':
        taps = firwin(numtaps, cutoff/nyq)
    elif btype == 'high':
        taps = firwin(numtaps, cutoff/nyq, pass_zero=False)
    elif btype == 'band':
        taps = firwin(numtaps, [cutoff[0]/nyq, cutoff[1]/nyq], pass_zero=False)
    try:
        return filtfilt(taps, [1.0], data)
    except ValueError:
        # fallback if padlen issue
        return filtfilt(taps, [1.0], data, method='gust')

def get_cutoff():
    stype = signal_type.get()
    if stype == "ECG":
        return [0.5, 40]
    elif stype == "Temperature":
        return [0.0001, 0.01]
    elif stype == "Respiration":
        return [0.1, 2]
    return [0.5, 40]

def apply_filter(filter_type):
    global processed_signal
    if fs is None:
        messagebox.showerror("Filter Error", "Sampling rate is invalid. Cannot apply filter.")
        return

    cutoff = get_cutoff()
    method = filter_method.get()

    if filter_type == "low":
        cutoff_val = cutoff[1]
    elif filter_type == "high":
        cutoff_val = cutoff[0]
    else:  # band
        cutoff_val = cutoff

    try:
        if method == "IIR":
            processed_signal = butter_filter(processed_signal, cutoff_val, fs, filter_type)
        else:
            processed_signal = fir_filter(processed_signal, cutoff_val, fs, filter_type)
    except Exception as e:
        messagebox.showerror("Filter Error", f"Failed to apply filter: {e}")
        return

    plot_time()

# ---------------------------
# FEATURE EXTRACTION
# ---------------------------
def compute_features():
    stype = signal_type.get()
    features = ""
    if fs is None or processed_signal is None:
        return ""
    if stype == "ECG":
        # Use first 10 seconds (or entire signal if shorter)
        win_samples = min(int(fs * 10), len(processed_signal))
        segment = processed_signal[:win_samples]
        # find_peaks requires distance >= 1
        min_dist = max(1, int(fs * 0.5))
        peaks, _ = find_peaks(segment, distance=min_dist, height=np.std(segment)*0.5)
        if len(peaks) < 2:
            bpm = 0.0
        else:
            duration = time[peaks[-1]] - time[peaks[0]]
            bpm = len(peaks) / duration * 60.0 if duration > 0 else 0.0
        features = f"Heart Rate: {bpm:.2f} BPM"
    elif stype == "Temperature":
        # Trend slope over entire signal
        duration = time[-1] - time[0] if len(time) > 1 else 1.0
        slope = (processed_signal[-1] - processed_signal[0]) / duration
        features = f"Trend Slope: {slope:.4f}"
    elif stype == "Respiration":
        min_dist = max(1, int(fs * 1.5))
        peaks, _ = find_peaks(processed_signal, distance=min_dist)
        if len(peaks) < 2:
            rate = 0.0
        else:
            duration = time[-1] - time[0]
            rate = len(peaks) / duration * 60.0 if duration > 0 else 0.0
        features = f"Breathing Rate: {rate:.2f} BPM"
    return features

# ---------------------------
# STATISTICS
# ---------------------------
def compute_stats():
    if processed_signal is None:
        return
    mean = np.mean(processed_signal)
    std = np.std(processed_signal)
    rms = np.sqrt(np.mean(processed_signal**2))
    p2p = np.ptp(processed_signal)
    feats = compute_features()
    stats_text.set(
        f"Mean: {mean:.3f}\nSTD: {std:.3f}\nRMS: {rms:.3f}\nPeak-Peak: {p2p:.3f}\n{feats}"
    )

# ---------------------------
# FFT
# ---------------------------
def show_fft():
    if processed_signal is None or fs is None:
        messagebox.showerror("FFT Error", "No signal to transform.")
        return
    N = len(processed_signal)
    yf = fft(processed_signal)
    xf = fftfreq(N, 1/fs)
    # Exclude the zero frequency component when finding dominant
    mag = np.abs(yf)
    if N > 1:
        # Skip DC term at index 0
        dominant_idx = np.argmax(mag[1:]) + 1
        dominant_freq = xf[dominant_idx]
    else:
        dominant_freq = 0.0
    plt.figure()
    plt.plot(xf[:N//2], mag[:N//2])
    plt.title(f"FFT (Dominant: {dominant_freq:.2f} Hz)")
    plt.xlabel("Frequency (Hz)")
    plt.ylabel("Magnitude")
    plt.grid()
    plt.show()

# ---------------------------
# PLOT
# ---------------------------
def plot_time():
    if time is None or original_signal is None:
        return
    plt.figure()
    plt.plot(time, original_signal, label="Raw", alpha=0.5)
    if processed_signal is not None:
        plt.plot(time, processed_signal, label="Processed")
    plt.legend()
    plt.title("Time Domain")
    plt.xlabel("Time (s)")
    plt.ylabel("Amplitude")
    plt.grid()
    plt.show()
    compute_stats()

# ---------------------------
# RESET
# ---------------------------
def reset_signal():
    global processed_signal
    if original_signal is None:
        return
    processed_signal = original_signal.copy()
    stats_text.set("")
    plot_time()

# ---------------------------
# GUI
# ---------------------------
root = tk.Tk()
root.title("Sensor Signal Processing Tool")
root.geometry("520x500")

tk.Label(root, text="Signal Processing Tool", font=("Arial",16)).pack(pady=10)

tk.Button(root, text="Load CSV", command=load_csv).pack(pady=5)

signal_type = tk.StringVar()
ttk.Combobox(root, textvariable=signal_type,
             values=("ECG","Temperature","Respiration")).pack(pady=5)

filter_method = tk.StringVar(value="IIR")
ttk.Combobox(root, textvariable=filter_method,
             values=("IIR","FIR")).pack(pady=5)

frame = tk.Frame(root); frame.pack(pady=10)
tk.Button(frame, text="LPF", command=lambda: apply_filter("low")).grid(row=0,column=0,padx=5)
tk.Button(frame, text="HPF", command=lambda: apply_filter("high")).grid(row=0,column=1,padx=5)
tk.Button(frame, text="BPF", command=lambda: apply_filter("band")).grid(row=0,column=2,padx=5)

tk.Button(root, text="Show FFT", command=show_fft).pack(pady=10)
tk.Button(root, text="Reset", command=reset_signal).pack(pady=5)

stats_text = tk.StringVar()
tk.Label(root, textvariable=stats_text, justify="left").pack(pady=20)

root.mainloop()
